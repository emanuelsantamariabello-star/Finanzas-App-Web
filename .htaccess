# Protección básica y recomendaciones para producción
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forzar HTTPS (descomentar en el servidor con certificado válido)
    #RewriteCond %{HTTPS} !=on
    #RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Evitar acceso directo a directorios sensibles
    RewriteRule ^(app|vendor|logs|database|routes|\.git)($|/) - [F,L]

    # Evitar servir el archivo de entorno
    <Files ".env.php">
        Require all denied
    </Files>
</IfModule>

# Evitar listados de directorio
Options -Indexes
# ======================================================
# FINANZAS APP — SEGURIDAD Y ENTRADA ÚNICA
# ======================================================

RewriteEngine On

# ======================================================
# 🔒 FORZAR HTTPS (DESCOMENTA SOLO EN PRODUCCIÓN)
# ======================================================
# RewriteCond %{HTTPS} off
# RewriteCond %{HTTP_HOST} !^localhost [NC]
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ======================================================
# 🚫 BLOQUEAR ARCHIVOS SENSIBLES
# ======================================================
<FilesMatch "^(\.env|\.env\.php|\.env\.example\.php|\.git|\.htaccess|\.gitignore|\.gitattributes|config\.php|verify_log\.txt)$">
    Require all denied
</FilesMatch>

# Bloquear archivos de configuración en subdirectorios
RewriteRule ^(app|vendor|config)/.+\.php$ - [F,L]

# ======================================================
# 🚫 BLOQUEAR CARPETAS INTERNAS
# ======================================================
RewriteRule ^(app|vendor|\.git|logs|database)(/|$) - [F,L]

# ======================================================
# 📄 CHARSET UTF-8 POR DEFECTO
# ======================================================
AddDefaultCharset UTF-8

# ======================================================
# 🗜️ COMPRESIÓN GZIP
# ======================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# ======================================================
# 💾 CACHE PARA ACTIVOS ESTÁTICOS
# ======================================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imágenes
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS y JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # HTML (no cachear, cambios frecuentes)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ======================================================
# 🔒 HEADERS DE SEGURIDAD
# ======================================================
<IfModule mod_headers.c>
    # Evitar clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Evitar MIME sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Protección XSS
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ======================================================
# 🧭 ENTRADA ÚNICA (DESCOMENTAR CUANDO IMPLEMENTE MVC)
# ======================================================
